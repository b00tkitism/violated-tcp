[general]
# VPS IP that is blocked by GFW - replace with your actual VPS IP
vps_ip = "192.168.1.5"
# Backend service IP (use 127.0.0.1 if running on same VPS)
xray_server_ip = "127.0.0.1"

[ports.tcp_mapping]
# local_port = remote_port
# Client listens on local_port, forwards to server's remote_port
14000 = 443
15000 = 2096
16000 = 10809

[ports.udp_mapping]
17000 = 945
18000 = 1014

[violation]
# These ports MUST be blocked by firewall (ufw deny / iptables DROP)
tcp_server_port = 45000
tcp_client_port = 40000
# Internal UDP ports for violation<->QUIC bridge
udp_server_port = 35000
udp_client_port = 30000

[quic]
server_port = 25000
client_port = 20000
local_ip = "127.0.0.1"
idle_timeout_secs = 86400
udp_timeout_secs = 300
verify_cert = false
mtu = 1420
cert_path = "cert.pem"
key_path = "key.pem"
max_data = 1073741824
max_stream_data = 1073741824
auth_code = "jd!gn0s4"
